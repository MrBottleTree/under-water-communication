<?xml version="1.0" encoding="utf-8"?>
<!-- Root: vertical LinearLayout so panels never overlap the camera area -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Camera preview + debug overlay: takes all remaining height -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.camera.view.PreviewView
            android:id="@+id/testPreviewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fitCenter" />

        <!-- Overlay: same size as the FrameLayout, non-interactive -->
        <com.example.underwaterlink.DebugOverlayView
            android:id="@+id/testDebugOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />

    </FrameLayout>

    <!-- ── Histogram panel: below camera, above controls, never overlaps ── -->
    <com.example.underwaterlink.HistogramPanelView
        android:id="@+id/histogramPanel"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#121212" />

    <!-- ── Control panel (fixed height, no overlap) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- Row 1: TX buttons + state + stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/testTxC1Button"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="TX C1"
                android:textSize="12sp"
                android:backgroundTint="#1565C0"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <Button
                android:id="@+id/testTxC2Button"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="TX C2"
                android:textSize="12sp"
                android:backgroundTint="#0D47A1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginStart="6dp" />

            <Button
                android:id="@+id/testStopTxButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="STOP TX"
                android:textSize="12sp"
                android:backgroundTint="#B71C1C"
                android:enabled="false"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginStart="6dp" />

            <Button
                android:id="@+id/testResetRxButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="RESET RX"
                android:textSize="12sp"
                android:backgroundTint="#4E342E"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginStart="6dp" />

            <TextView
                android:id="@+id/testStateText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="RX: IDLE"
                android:textColor="#00FF00"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/testStatsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="ERR 0/0"
                android:textColor="#FFEB3B"
                android:textSize="13sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Row 2: Histogram mode toggle + slider (shared for α and N) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <!-- Toggle switches between α-decay and rolling-window modes.
                 OFF = alpha decay,  ON = rolling window of N frames -->
            <ToggleButton
                android:id="@+id/modeToggle"
                android:layout_width="62dp"
                android:layout_height="30dp"
                android:textOff="α dec"
                android:textOn="N win"
                android:textSize="10sp"
                android:checked="false"
                android:backgroundTint="#333333" />

            <!-- Dual-purpose SeekBar: α-decay mode → (p+1)/1000 ; N-window mode → p+1 -->
            <SeekBar
                android:id="@+id/alphaSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="999"
                android:progress="49" />

            <TextView
                android:id="@+id/alphaValueText"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="α=0.050"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Row 3: Confidence threshold slider (0.00 – 1.00) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:layout_width="62dp"
                android:layout_height="wrap_content"
                android:text="conf thr"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <!-- progress 0–100 → conf = p/100 = 0.00 to 1.00 -->
            <SeekBar
                android:id="@+id/confSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="15" />

            <TextView
                android:id="@+id/confValueText"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="0.150"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Row 4: Grid size slider (4, 8, 16, 32 px) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:layout_width="62dp"
                android:layout_height="wrap_content"
                android:text="grid px"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <!-- progress 0–3 → gridSize = 4 << p = 4,8,16,32 -->
            <SeekBar
                android:id="@+id/gridSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="3"
                android:progress="1" />

            <TextView
                android:id="@+id/gridValueText"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="8px"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
