<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090E14"
    android:orientation="horizontal"
    android:padding="12dp"
    android:weightSum="3">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.8"
        android:background="#111A24"
        android:orientation="vertical"
        android:padding="12dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Controls"
                    android:textColor="#E6EEF9"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Zoom"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/zoomSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="#1C2A38"
                        android:popupBackground="#1C2A38" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Signal TX"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Spinner
                            android:id="@+id/signalSpinner"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="#1C2A38"
                            android:popupBackground="#1C2A38" />

                        <EditText
                            android:id="@+id/qPacketNoInput"
                            android:layout_width="68dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:background="#1C2A38"
                            android:digits="0123456789"
                            android:gravity="center"
                            android:hint="Q#"
                            android:inputType="number"
                            android:maxLength="3"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:textColor="#E6EEF9"
                            android:textColorHint="#8DA3B5"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/testTransmitSignalButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:backgroundTint="#1565C0"
                            android:text="Transmit Signal"
                            android:textAllCaps="false"
                            android:textSize="12sp" />

                        <Button
                            android:id="@+id/testStopTxButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="#B71C1C"
                            android:enabled="false"
                            android:text="Stop Transmitting"
                            android:textAllCaps="false"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Sync"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/autoSyncButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:backgroundTint="#004D40"
                            android:text="Start Sync"
                            android:textAllCaps="false"
                            android:textSize="12sp" />

                        <Button
                            android:id="@+id/stopSyncButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="#B71C1C"
                            android:text="Stop Sync"
                            android:textAllCaps="false"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Message"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/syncMessageInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#1C2A38"
                        android:gravity="top|start"
                        android:hint="Sync message (max 80 chars)"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLength="80"
                        android:maxLines="3"
                        android:minHeight="84dp"
                        android:padding="10dp"
                        android:textColor="#E6EEF9"
                        android:textColorHint="#8DA3B5"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Parameters"
                        android:textColor="#E6EEF9"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ToggleButton
                        android:id="@+id/modeToggle"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="10dp"
                        android:backgroundTint="#2A3A4B"
                        android:checked="false"
                        android:textOff="Alpha Mode"
                        android:textOn="Window N Mode"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/alphaParamLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Alpha"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/alphaParamInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="#1C2A38"
                        android:digits="0123456789."
                        android:hint="0.050 or 30"
                        android:inputType="numberDecimal"
                        android:padding="10dp"
                        android:textColor="#E6EEF9"
                        android:textColorHint="#8DA3B5"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Alpha Threshold Confidence"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/confParamInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="#1C2A38"
                        android:digits="0123456789."
                        android:hint="0.150"
                        android:inputType="numberDecimal"
                        android:padding="10dp"
                        android:textColor="#E6EEF9"
                        android:textColorHint="#8DA3B5"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Grid Size"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/gridParamInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="#1C2A38"
                        android:digits="0123456789"
                        android:hint="8"
                        android:inputType="number"
                        android:padding="10dp"
                        android:textColor="#E6EEF9"
                        android:textColorHint="#8DA3B5"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/testResetRxButton"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:backgroundTint="#4E342E"
                        android:text="Reset RX"
                        android:textAllCaps="false"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.4"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:background="#0E1722">

        <androidx.camera.view.PreviewView
            android:id="@+id/testPreviewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:implementationMode="compatible"
            app:scaleType="fillCenter" />

        <com.example.underwaterlink.DebugOverlayView
            android:id="@+id/testDebugOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:background="#66000000"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="Camera"
            android:textColor="#E6EEF9"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.8"
        android:background="#111A24"
        android:orientation="horizontal"
        android:padding="12dp"
        android:weightSum="10">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#0E1824"
            android:padding="4dp"
            android:paddingEnd="8dp">

            <com.example.underwaterlink.HistogramPanelView
                android:id="@+id/histogramPanel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:minWidth="26dp"
                android:background="#121212" />
        </LinearLayout>

        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="9"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="6dp"
                android:paddingEnd="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Status / Histogram"
                    android:textColor="#E6EEF9"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Current State"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/testStateText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="monospace"
                        android:text="IDLE"
                        android:textColor="#00E676"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="8dp"
                        android:background="#263648" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Current Role (A/B)"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/syncStateText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="monospace"
                        android:text="A"
                        android:textColor="#00E5FF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="8dp"
                        android:background="#263648" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Signal Received"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/testStatsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="(none)"
                        android:textColor="#FFEE58"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Decoded (latest 20 chars)"
                        android:textColor="#9AA7B2"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/testDecodedWindowText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#152332"
                        android:fontFamily="monospace"
                        android:padding="10dp"
                        android:text="(none)"
                        android:textColor="#E6EEF9"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</LinearLayout>
