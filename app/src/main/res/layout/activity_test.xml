<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090E14"
    android:orientation="horizontal"
    android:padding="12dp"
    android:weightSum="3">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#111A24"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Controls"
            android:textColor="#E6EEF9"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:fontFamily="monospace"
                        android:text="zoom"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/zoom1xButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:backgroundTint="#1B5E20"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="1x"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/zoom2xButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="4dp"
                        android:backgroundTint="#2A3A4B"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="2x"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/zoom4xButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="4dp"
                        android:backgroundTint="#2A3A4B"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="4x"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/zoomLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:text="1x (640x480)"
                        android:textColor="#E6EEF9"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/testTxC1Button"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:backgroundTint="#1565C0"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="TX C1"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/testTxC2Button"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="6dp"
                        android:backgroundTint="#0D47A1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="TX C2"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/testStopTxButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="6dp"
                        android:backgroundTint="#B71C1C"
                        android:enabled="false"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="STOP TX"
                        android:textSize="12sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/testResetRxButton"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:layout_marginBottom="8dp"
                    android:backgroundTint="#4E342E"
                    android:text="RESET RX"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ToggleButton
                        android:id="@+id/modeToggle"
                        android:layout_width="70dp"
                        android:layout_height="34dp"
                        android:backgroundTint="#2A3A4B"
                        android:checked="false"
                        android:textOff="A dec"
                        android:textOn="N win"
                        android:textSize="10sp" />

                    <SeekBar
                        android:id="@+id/alphaSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="999"
                        android:progress="49" />

                    <TextView
                        android:id="@+id/alphaValueText"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="monospace"
                        android:text="A=0.050"
                        android:textColor="#E6EEF9"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="conf thr"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp" />

                    <SeekBar
                        android:id="@+id/confSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="15" />

                    <TextView
                        android:id="@+id/confValueText"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="monospace"
                        android:text="0.150"
                        android:textColor="#E6EEF9"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="grid px"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp" />

                    <SeekBar
                        android:id="@+id/gridSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="3"
                        android:progress="1" />

                    <TextView
                        android:id="@+id/gridValueText"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="monospace"
                        android:text="8px"
                        android:textColor="#E6EEF9"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/autoSyncButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:backgroundTint="#004D40"
                        android:text="AUTO SYNC"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/stopSyncButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:backgroundTint="#B71C1C"
                        android:text="STOP SYNC"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#0E1722">

        <androidx.camera.view.PreviewView
            android:id="@+id/testPreviewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter" />

        <com.example.underwaterlink.DebugOverlayView
            android:id="@+id/testDebugOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:background="#66000000"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="Camera"
            android:textColor="#E6EEF9"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#111A24"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Status / Histogram"
            android:textColor="#E6EEF9"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/testStateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="RX: IDLE"
            android:textColor="#00E676"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/testStatsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:text="ERR 0/0"
            android:textColor="#FFEE58"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/syncStateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:text="SYNC: OFF"
            android:textColor="#00E5FF"
            android:textSize="12sp" />

        <com.example.underwaterlink.HistogramPanelView
            android:id="@+id/histogramPanel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:background="#121212" />
    </LinearLayout>

</LinearLayout>
