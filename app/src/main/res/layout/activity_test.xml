<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_test.xml — 3-column horizontal layout
    Left: Controls (weight 0.8) | Center: Camera (weight 1.6) | Right: Status (weight 0.8)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090E14"
    android:orientation="horizontal"
    android:weightSum="3.2">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- LEFT PANEL — Controls (scrollable)                             -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.8"
        android:background="#111A24"
        android:orientation="vertical"
        android:padding="10dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Section header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Controls"
                    android:textColor="#E6EEF9"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- ── Zoom group ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Zoom"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp"
                        android:textAllCaps="true" />

                    <Spinner
                        android:id="@+id/zoomSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="#1C2A38"
                        android:popupBackground="#1C2A38" />
                </LinearLayout>

                <!-- ── Manual TX group ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Manual TX"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp"
                        android:textAllCaps="true" />

                    <Spinner
                        android:id="@+id/signalSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="6dp"
                        android:background="#1C2A38"
                        android:popupBackground="#1C2A38" />

                    <!-- Q:no input — shown only when "Q:no" is selected -->
                    <EditText
                        android:id="@+id/qPacketNoInput"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="6dp"
                        android:background="#1C2A38"
                        android:digits="0123456789"
                        android:gravity="start|center_vertical"
                        android:hint="Pkt# 0-15"
                        android:inputType="number"
                        android:maxLength="2"
                        android:padding="8dp"
                        android:textColor="#E6EEF9"
                        android:textColorHint="#8DA3B5"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- Packet message input — shown only when "Packet" is selected -->
                    <EditText
                        android:id="@+id/packetMessageInput"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="6dp"
                        android:background="#1C2A38"
                        android:gravity="start|center_vertical"
                        android:hint="5 chars for packet"
                        android:inputType="text"
                        android:maxLength="5"
                        android:padding="8dp"
                        android:textColor="#E6EEF9"
                        android:textColorHint="#8DA3B5"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/testTransmitSignalButton"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="6dp"
                        android:backgroundTint="#1565C0"
                        android:text="Send Signal"
                        android:textAllCaps="false"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/testStopTxButton"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:backgroundTint="#B71C1C"
                        android:enabled="false"
                        android:text="Stop TX"
                        android:textAllCaps="false"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- ── Protocol group ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Protocol"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp"
                        android:textAllCaps="true" />

                    <EditText
                        android:id="@+id/syncMessageInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="#1C2A38"
                        android:gravity="top|start"
                        android:hint="Message (max 80 chars)"
                        android:inputType="textMultiLine"
                        android:maxLength="80"
                        android:maxLines="3"
                        android:minHeight="72dp"
                        android:padding="10dp"
                        android:textColor="#E6EEF9"
                        android:textColorHint="#8DA3B5"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/autoSyncButton"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="6dp"
                        android:backgroundTint="#004D40"
                        android:text="Start Protocol"
                        android:textAllCaps="false"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/stopSyncButton"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:backgroundTint="#B71C1C"
                        android:enabled="false"
                        android:text="Stop Protocol"
                        android:textAllCaps="false"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Spacer — pushes Parameters to bottom when content is short -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- ── RX Parameters group ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="RX Parameters"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp"
                        android:textAllCaps="true" />

                    <ToggleButton
                        android:id="@+id/modeToggle"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginBottom="8dp"
                        android:backgroundTint="#2A3A4B"
                        android:checked="false"
                        android:textOff="Alpha Mode"
                        android:textOn="Window N Mode"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/alphaParamLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Alpha"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/alphaParamInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:background="#1C2A38"
                        android:digits="0123456789."
                        android:hint="0.050 or 30"
                        android:inputType="numberDecimal"
                        android:padding="8dp"
                        android:textColor="#E6EEF9"
                        android:textColorHint="#8DA3B5"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Conf Threshold"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/confParamInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:background="#1C2A38"
                        android:digits="0123456789."
                        android:hint="0.150"
                        android:inputType="numberDecimal"
                        android:padding="8dp"
                        android:textColor="#E6EEF9"
                        android:textColorHint="#8DA3B5"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Grid Size"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/gridParamInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="#1C2A38"
                        android:digits="0123456789"
                        android:hint="8"
                        android:inputType="number"
                        android:padding="8dp"
                        android:textColor="#E6EEF9"
                        android:textColorHint="#8DA3B5"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/testResetRxButton"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:backgroundTint="#4E342E"
                        android:text="Reset RX"
                        android:textAllCaps="false"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- CENTER PANEL — Camera feed (no padding, full height)           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.6"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:background="#0E1722">

        <androidx.camera.view.PreviewView
            android:id="@+id/testPreviewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:implementationMode="compatible"
            app:scaleType="fitCenter" />

        <com.example.underwaterlink.DebugOverlayView
            android:id="@+id/testDebugOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />

        <!-- "Camera" label chip in top-left corner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="10dp"
            android:background="#66000000"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:text="Camera"
            android:textColor="#E6EEF9"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- RIGHT PANEL — Status + Logs (fully scrollable)                 -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.8"
        android:background="#111A24"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp">

        <!-- Section header (fixed, outside scroll) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Status"
            android:textColor="#E6EEF9"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Single ScrollView wrapping ALL content so user can scroll entire panel -->
        <ScrollView
            android:id="@+id/rightScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── State group ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Protocol State"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/testStateText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="monospace"
                        android:text="OFF"
                        android:textColor="#00E676"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="8dp"
                        android:background="#263648" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Role"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/syncStateText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="monospace"
                        android:text="&#8212;"
                        android:textColor="#00E5FF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="8dp"
                        android:background="#263648" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Last Bit"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/testStatsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="(none)"
                        android:textColor="#FFEE58"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- ── Received Message group ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Received Message"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/testDecodedWindowText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#152332"
                        android:fontFamily="monospace"
                        android:padding="10dp"
                        android:text="(none)"
                        android:textColor="#E6EEF9"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- ── Signal Log group ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="#0E1824"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Signal Log"
                        android:textColor="#9AA7B2"
                        android:textSize="11sp"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/signalLogText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#0A1520"
                        android:fontFamily="monospace"
                        android:minHeight="60dp"
                        android:padding="8dp"
                        android:text=""
                        android:textColor="#80CBC4"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- ── Event Log (fixed height, own inner scroll) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#0E1824"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Event Log"
                android:textColor="#9AA7B2"
                android:textSize="11sp"
                android:textAllCaps="true" />

            <ScrollView
                android:id="@+id/eventLogScrollView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/eventLogText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0A1520"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text=""
                    android:textColor="#90CAF9"
                    android:textSize="11sp" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
