<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UnderwaterLink TX"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/messageInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter message to transmit..."
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:backgroundTint="#4CAF50"
        android:inputType="text"
        android:padding="10dp"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/transmitButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TRANSMIT"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/stopButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="STOP"
        android:backgroundTint="#F44336"
        android:visibility="gone"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/receiveButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RECEIVE (RoI camera)"
        android:backgroundTint="#1565C0"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Idle"
        android:textColor="#AAAAAA"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/rateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TX Rate: -- bps"
        android:textColor="#4CAF50"
        android:textStyle="bold"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/currentBitText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current bit: -"
        android:textColor="#FFEB3B"
        android:layout_marginTop="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Binary Output:"
        android:textColor="#AAAAAA"
        android:layout_marginTop="8dp" />

    <ScrollView
        android:id="@+id/binaryScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E"
        android:padding="8dp"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/binaryOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF00"
            android:textSize="12sp"
            android:fontFamily="monospace" />

    </ScrollView>

</LinearLayout>
